# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=change-this-strong-password

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRE_MINUTES=10080

# ── URLs ──────────────────────────────────────────────────────────────────────
# Public URL of the frontend (used for CORS and OIDC redirects)
FRONTEND_URL=https://careerforge.example.com

# Port the frontend container publishes on the host (reverse proxy points here)
FRONTEND_PORT=3000

# ── Authentik SSO (optional — leave blank to disable the SSO button) ──────────
AUTHENTIK_URL=https://auth.example.com
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
# /api/auth/oidc/callback is proxied by nginx to the backend
AUTHENTIK_REDIRECT_URI=https://careerforge.example.com/api/auth/oidc/callback
